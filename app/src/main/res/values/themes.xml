<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Bethesda" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/navy</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="colorSecondaryVariant">@color/gold_light</item>
        <item name="colorOnSecondary">@color/navy_dark</item>
        <item name="android:statusBarColor">@color/navy</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/navy</item>
    </style>

    <style name="Theme.Bethesda.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/navy</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Bethesda</item>
    </style>

</resources>
