<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="14dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/testimonialStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.15"
            android:textColor="@color/secondary"
            android:textSize="14sp"
            tools:text="★★★★★" />

        <TextView
            android:id="@+id/testimonialQuote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/work_sans"
            android:gravity="center"
            android:maxLines="5"
            android:ellipsize="end"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="italic"
            tools:text="“Bethesda Biblical Institute equipped me to serve my congregation with confidence and clarity.”" />

        <ImageView
            android:id="@+id/testimonialAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginTop="14dp"
            android:background="@color/surface_container"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/testimonialName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/playfair_display"
            android:textColor="@color/ink_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Rev. John Carter" />

        <TextView
            android:id="@+id/testimonialRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/work_sans"
            android:textColor="@color/gray"
            android:textSize="12sp"
            tools:text="Diploma Graduate, 2024" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
