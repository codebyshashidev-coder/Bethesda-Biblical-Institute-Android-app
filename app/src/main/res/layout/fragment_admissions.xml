<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_gradient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="32dp">

                <TextView
                    style="@style/Label.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEGIN YOUR CALLING" />

                <TextView
                    style="@style/Headline.Display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Join the Global Harvest"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/work_sans"
                    android:gravity="center"
                    android:text="Empowering leaders through flexible, distance theological education rooted in Scripture and sound doctrine."
                    android:textColor="#D3E4FF"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/applyOnlineButton"
                    style="@style/Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="Apply Online Now"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admissionProcessButton"
                    style="@style/Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="Admission Process"
                    android:textSize="15sp" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background_cream"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/Headline.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Affiliation &amp; Accreditation"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/work_sans"
                android:text="Building institutional authority through global theological networks and academic rigor."
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/affiliationButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:fontFamily="@font/work_sans"
                android:text="View Affiliation Details"
                android:textAllCaps="false"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/Headline.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How to Apply"
                android:textSize="20sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/work_sans"
                android:lineSpacingExtra="6dp"
                android:text="✝  Fill out the online application form\n✝  Upload your photo, ID, and any prior certificates\n✝  Our admissions team reviews your submission\n✝  Begin your first term upon acceptance"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
