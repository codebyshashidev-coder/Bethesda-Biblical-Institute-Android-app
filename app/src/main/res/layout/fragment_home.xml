<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top brand bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/playfair_display"
                android:text="✝ BBI"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/enquireButton"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/work_sans"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Enquire"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="6dp" />
        </LinearLayout>

        <!-- Hero -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_gradient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="56dp"
                android:paddingBottom="48dp">

                <TextView
                    android:id="@+id/heroTitle"
                    style="@style/Headline.Display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to Bethesda Biblical Institute"
                    android:textSize="30sp" />

                <TextView
                    android:id="@+id/heroSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/work_sans"
                    android:text="Equipping Ministers of the Gospel through Distance Theological Education"
                    android:textColor="#D3E4FF"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/applyNowButton"
                    style="@style/Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:text="Apply Now"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/learnMoreButton"
                    style="@style/Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="Learn More"
                    android:textSize="15sp" />

            </LinearLayout>
        </FrameLayout>

        <!-- Why study with us -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background_cream"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/Headline.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Why Study With Us"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/whyBullet1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/work_sans"
                android:text="✝  Accredited, Bible-centered theological curriculum"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/work_sans"
                android:text="✝  Flexible distance learning for working ministers"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/work_sans"
                android:text="✝  Programs from Certificate through Doctoral level"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Testimonials -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="4dp">

            <TextView
                style="@style/Headline.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:text="What Our Students Say"
                android:textSize="20sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/testimonialsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="8dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_testimonial_card" />

        </LinearLayout>

        <!-- Latest news -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Headline.Section"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Latest News"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/viewAllNewsLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/work_sans"
                    android:text="View All"
                    android:textColor="@color/secondary"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/newsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_news_card" />

            <TextView
                android:id="@+id/newsEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/work_sans"
                android:gravity="center"
                android:text="Loading news…"
                android:textColor="@color/gray"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
